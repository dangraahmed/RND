{
  "$schema": "https://raw.githubusercontent.com/JanDeDobbeleer/oh-my-posh/main/themes/schema.json",
  "palette": {
    "bg": "#3f3f3f",
    "separator-fg": "#919191",
    "fg-path": "#43CCEA",
    "fg-git": "#39FF14"
  },
  "blocks": [
    {
      "type": "prompt",
      "alignment": "left",
      "segments": [
        {
          "properties": {
            "cache_duration": "none",
            "mixed_threshold": 6,
            "style": "folder"
          },
          "template": " \uf07b <b>{{ .Path }}</b> ",
          "foreground": "p:fg-path",
          "type": "path",
          "style": "diamond"
        },
        {
          "properties": {
            "branch_icon": "\ue725 ",
            "cache_duration": "none",
            "fetch_stash_count": true,
            "fetch_status": true
          },
          "template": "<p:separator-fg></><b>{{.HEAD}} {{.BranchStatus}}{{ if or (.Working.Changed) (.Staging.Changed) }} |{{ end }}{{ if .Working.Changed }}{{ .Working.String }}{{ end }}{{ if .Staging.Changed }} \uf046 {{ .Staging.String }}{{ end }}</b> ",
          "foreground": "p:fg-git",
          "type": "git",
          "style": "diamond"
        }
      ],
      "newline": true
    },
    {
      "type": "prompt",
      "alignment": "right",
      "segments": [
        {
          "properties": {
            "always_enabled": true,
            "cache_duration": "none"
          },
          "template": " <b>{{ .FormattedMs }}</b> ",
          "foreground": "p:fg-git",
          "foreground_templates": [
            "{{ if gt .Code 0 }}red{{ end }}"
          ],
          "type": "executiontime",
          "style": "diamond"
        }
      ]
    },
    {
      "type": "prompt",
      "alignment": "left",
      "segments": [
        {
          "template": " {{.Icon}}  \ue285 ",
          "foreground": "p:fg-git",
          "type": "os",
          "style": "diamond"
        }
      ],
      "newline": true
    }
  ],
  "version": 3
}
